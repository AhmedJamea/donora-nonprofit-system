@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "My Giving History";
}

<div class="container mt-4">
    @* Consistent Navigation Header *@
    <div class="mb-4 mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-house-door"></i> Back to Portal
        </a>
        <a asp-controller="Supporter" asp-action="Index" class="btn btn-sm btn-outline-primary ms-2">
            <i class="bi bi-search"></i> Browse Initiatives
        </a>
    </div>

    @* Page Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">My Contribution History</h2>
            <p class="text-muted small">A record of your support for humanitarian projects.</p>
        </div>
        @* Visual summary badge *@
        <div class="badge bg-success p-2 px-3 shadow-sm">
            <i class="bi bi-patch-check-fill me-1"></i> Active Supporter
        </div>
    </div>

    @if (!Model.Any())
    {
        @* Enhanced Empty State *@
        <div class="card border-0 shadow-sm bg-light py-5 text-center">
            <div class="card-body">
                <i class="bi bi-heart-pulse display-4 text-muted mb-3"></i>
                <h4>No contributions yet</h4>
                <p class="text-muted">You haven't made any donations to our active initiatives.</p>
                <a asp-action="Index" class="btn btn-primary px-4">
                    Explore Projects and Make an Impact
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Project Name</th>
                            <th class="text-center">Donation Amount</th>
                            <th class="text-center pe-4">Date of Contribution</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.ProjectName</div>
                                    <div class="x-small text-muted text-uppercase">Direct Funding</div>
                                </td>
                                <td class="text-center fw-bold text-success">
                                    @item.Amount.ToString("C2")
                                </td>
                                <td class="text-center text-muted pe-4">
                                    <i class="bi bi-calendar3 me-2 small"></i>@item.Date.ToString("MMMM dd, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Impact Summary Section *@
        <div class="mt-4 p-4 bg-white border rounded shadow-sm d-flex justify-content-between align-items-center">
            <div class="text-muted">
                <i class="bi bi-info-circle me-1"></i>
                Thank you for your generosity. Your total contributions support global progress.
            </div>
            <div class="text-end">
                <span class="h5 text-muted me-2">Total Impact:</span>
                <span class="h3 fw-bold text-success">
                    @Model.Sum(x => (decimal)x.Amount).ToString("C2")
                </span>
            </div>
        </div>
    }
</div>

<style>
    .x-small {
        font-size: 0.7rem;
    }

    .table thead th {
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }
</style>