@using Donora.Models.Entities
@{
    ViewData["Title"] = "Browse Initiatives";
    // We cast the ViewBag data to specific types for better IntelliSense and safety
    var sectors = ViewBag.Sectors as IEnumerable<Sector> ?? new List<Sector>();
    var initiatives = ViewBag.Initiatives as IEnumerable<Initiative> ?? new List<Initiative>();
}

<div class="container mt-4">
    @* Consistent Navigation Header *@
    <div class="mb-4 mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-house-door"></i> Back to Portal
        </a>
    </div>

    @* Success Messages for completed donations *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-heart-fill me-2"></i> <strong>Thank You!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="fw-bold mb-0">Current Initiatives</h1>
            <p class="text-muted">Choose a cause to support and track your impact in real-time.</p>
        </div>
        <a asp-controller="Supporter" asp-action="MyContributions" class="btn btn-info text-dark shadow-sm">
            <i class="bi bi-clock-history me-2"></i>My Giving History &rarr;
        </a>
    </div>

    @foreach (var sector in sectors)
    {
        @* Filter initiatives for this specific sector *@
        var sectorInitiatives = initiatives.Where(i => i.SectorId == sector.SectorId).ToList();

        @if (sectorInitiatives.Any())
        {
            <div class="mb-5">
                <h3 class="text-primary fw-bold border-bottom pb-2 mb-4">
                    <i class="bi bi-tag-fill me-2 small"></i>@sector.Name
                </h3>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var initiative in sectorInitiatives)
                    {
                        @* Calculate percentage for the progress bar *@
                        var percentage = initiative.FundingTarget > 0
                        ? (int)Math.Min((initiative.CurrentRaised / initiative.FundingTarget) * 100, 100)
                        : 0;

                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 transition-hover">
                                <div class="card-body">
                                    <h5 class="card-title fw-bold text-dark mb-3">@initiative.InitiativeName</h5>
                                    <p class="card-text text-muted small mb-4" style="height: 4.5rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                        @initiative.Objective
                                    </p>

                                    @* Progress Bar Section *@
                                    <div class="mt-auto">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="small fw-bold text-success">@percentage% funded</span>
                                            <span class="small text-muted">@initiative.CurrentRaised.ToString("C0") raised</span>
                                        </div>
                                        <div class="progress mb-2" style="height: 8px; background-color: #f0f0f0;">
                                            <div class="progress-bar bg-success" role="progressbar"
                                                 style="width: @percentage%"
                                                 aria-valuenow="@percentage"
                                                 aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <small class="text-secondary fw-bold">Goal: @initiative.FundingTarget.ToString("C0")</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-top-0 p-3">
                                    <a asp-action="Donate" asp-route-initiativeId="@initiative.InitiativeId"
                                       class="btn btn-success w-100 fw-bold py-2">
                                        Donate Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
</style>