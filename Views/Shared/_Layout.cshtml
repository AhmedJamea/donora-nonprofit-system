<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Donora</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar-brand {
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
        }

        .footer {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-globe-americas me-2"></i>DONORA
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @* 1. Public Link: Portal Home *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Portal</a>
                        </li>

                        @* 2. Role-Based Navigation Logic *@
                        @{
                            var role = Context.Session.GetString("UserRole");
                        }

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Admin" asp-action="ManageInitiatives">Manage</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Reports">Impact Reports</a>
                            </li>
                        }
                        else if (role == "Supporter")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Supporter" asp-action="Index">Browse Initiatives</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Supporter" asp-action="MyContributions">My Giving</a>
                            </li>
                        }
                    </ul>

                    @* 3. Identity/Account Links *@
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("Username") != null)
                        {
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="badge bg-light text-dark border p-2">
                                    <i class="bi bi-person-circle me-1"></i> @Context.Session.GetString("Username") (@role)
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm px-3" asp-controller="Account" asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-4" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 - Donora - Humanitarian Impact Tracker</p>
            <small><a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy Policy</a></small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* CRITICAL FIX: This renders the Scripts section defined in your Views (Create, Edit, etc.) *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>