@model Donora.Models.Entities.Initiative

<div class="container mt-4">
    @* Consistent Navigation Header *@
    <div class="mb-4 mt-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-speedometer2"></i> Back to Dashboard
        </a>
        <a asp-controller="Admin" asp-action="ManageInitiatives" class="btn btn-sm btn-outline-primary ms-2">
            <i class="bi bi-list-task"></i> View All Initiatives
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Edit Initiative: @Model.InitiativeName
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @* CRITICAL: Hidden ID allows the Repository Update condition to function *@
                        <input type="hidden" asp-for="InitiativeId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="InitiativeName" class="form-label fw-bold">Initiative Name</label>
                                <input asp-for="InitiativeName" class="form-control" placeholder="Update initiative name..." required />
                                <span asp-validation-for="InitiativeName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="SectorId" class="form-label fw-bold">Sector</label>
                                <select asp-for="SectorId" class="form-select"
                                        asp-items="@(new SelectList(ViewBag.Sectors, "SectorId", "Name"))">
                                </select>
                                <span asp-validation-for="SectorId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Objective" class="form-label fw-bold">Project Objective</label>
                            <textarea asp-for="Objective" class="form-control" rows="3" placeholder="Update the humanitarian impact goals..."></textarea>
                            <span asp-validation-for="Objective" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="FundingTarget" class="form-label fw-bold">Funding Target ($)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">$</span>
                                    <input asp-for="FundingTarget" type="number" step="0.01" class="form-control" required />
                                </div>
                                <span asp-validation-for="FundingTarget" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control"
                                       value="@Model.StartDate.ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="EndDate" class="form-label fw-bold">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control"
                                       value="@Model.EndDate.ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                            <a asp-action="ManageInitiatives" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">
                                <i class="bi bi-check2-circle me-2"></i>Update Initiative
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Audit Information (Optional: Visual reminder for the Admin) *@
            @if (Model.CurrentRaised > 0)
            {
                <div class="alert alert-info mt-3 shadow-sm border-0">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>Audit Note:</strong> This project has already raised <strong>@Model.CurrentRaised.ToString("C0")</strong>.
                    Be cautious when modifying the Funding Target or Deadlines.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}