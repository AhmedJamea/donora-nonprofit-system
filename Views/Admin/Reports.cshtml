@model dynamic

<div class="container mt-4">
    @* Consistent Navigation Header *@
    <div class="mb-4 mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-house-door"></i> Back to Portal
        </a>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-dark ms-2">
            <i class="bi bi-speedometer2"></i> Admin Dashboard
        </a>
        <a asp-controller="Admin" asp-action="ManageInitiatives" class="btn btn-sm btn-outline-primary ms-2">
            <i class="bi bi-kanban"></i> Manage Initiatives
        </a>
    </div>

    <h2 class="fw-bold mb-4">Organizational Impact & Financial Reports</h2>

    <div class="row g-4">
        @* Top Performers *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 bg-primary text-white">
                <div class="card-body py-4">
                    <h6 class="text-uppercase small opacity-75 fw-bold mb-2">
                        <i class="bi bi-star-fill me-2"></i>Top Sector (Max Contributions)
                    </h6>
                    <h3 class="fw-bold mb-0">@Model.TopSector</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0 bg-success text-white">
                <div class="card-body py-4">
                    <h6 class="text-uppercase small opacity-75 fw-bold mb-2">
                        <i class="bi bi-person-heart me-2"></i>Top Supporter (Last Month)
                    </h6>
                    <h3 class="fw-bold mb-0">@Model.TopSupporter</h3>
                </div>
            </div>
        </div>

        @* Red Flags Section *@
        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-warning text-dark fw-bold border-0">
                    <i class="bi bi-flag-fill me-2"></i>No Contributions (Last Month)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.SlowInitiatives.Count == 0)
                    {
                        <li class="list-group-item text-muted italic">No red flags found. All projects received funding.</li>
                    }
                    else
                    {
                        @foreach (var name in Model.SlowInitiatives)
                        {
                            <li class="list-group-item">@name</li>
                        }
                    }
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-danger text-white fw-bold border-0">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i>No Expenditure (Last Month)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.NoSpendInitiatives.Count == 0)
                    {
                        <li class="list-group-item text-muted">All projects recorded activity.</li>
                    }
                    else
                    {
                        @foreach (var name in Model.NoSpendInitiatives)
                        {
                            <li class="list-group-item text-danger fw-semibold">@name</li>
                        }
                    }
                </ul>
            </div>
        </div>

        @* Active Initiatives Table *@
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold border-0">
                    Active Initiatives per Sector (Last Month)
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Sector</th>
                                    <th>Initiative Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ActiveLastMonth.Count == 0)
                                {
                                    <tr><td colspan="2" class="text-center py-4 text-muted">No active initiatives found for the previous month.</td></tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.ActiveLastMonth)
                                    {
                                        <tr>
                                            <td class="ps-3"><span class="badge rounded-pill bg-secondary px-3">@item.Sector</span></td>
                                            <td class="fw-semibold">@item.Name</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* Supporter Engagement Grid *@
        <div class="col-md-12">
            <div class="card shadow-sm mb-5 border-0">
                <div class="card-header bg-info text-white fw-bold border-0">
                    <i class="bi bi-people-fill me-2"></i>Supporter Engagement Profiles
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @if (Model.SupporterStats.Count == 0)
                        {
                            <div class="col-12 text-center py-4 text-muted">No supporter data available.</div>
                        }
                        else
                        {
                            @foreach (var sup in Model.SupporterStats)
                            {
                                <div class="col-md-3">
                                    <div class="p-3 border rounded shadow-xs text-center bg-white h-100">
                                        <div class="fw-bold text-dark h5 mb-1">@sup.User</div>
                                        <div class="badge bg-light text-primary border">@sup.Count Projects Funded</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>