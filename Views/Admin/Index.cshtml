@model dynamic

<div class="container mt-4">
    <div class="mb-4 mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Portal
        </a>
    </div>

    <h2 class="fw-bold mb-4">Admin Dashboard</h2>
    <hr />

    <div class="row g-4">
        @* Card 1: Total Contributions *@
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3 shadow border-0">
                <div class="card-body text-center py-4">
                    <h5 class="card-title">Total Contributions</h5>
                    @* REFACTOR: Switched from ViewBag to Model *@
                    <h2 class="display-4 fw-bold">@Model.TotalFunds.ToString("C2")</h2>
                    <p class="card-text opacity-75">Total funds raised for all initiatives.</p>
                </div>
            </div>
        </div>

        @* Card 2: Active Initiatives *@
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3 shadow border-0">
                <div class="card-body text-center py-4">
                    <h5 class="card-title">Active Initiatives</h5>
                    @* REFACTOR: Switched from ViewBag to Model *@
                    <h2 class="display-4 fw-bold">@Model.ActiveCount</h2>
                    <p class="card-text opacity-75">Projects currently within their active dates.</p>
                </div>
            </div>
        </div>

        @* Card 3: Low Funding Alerts *@
        <div class="col-md-4">
            <div class="card text-white bg-danger mb-3 shadow border-0">
                <div class="card-body text-center py-4">
                    <h5 class="card-title">Low Funding Alerts</h5>
                    @* REFACTOR: Switched from ViewBag to Model *@
                    <h2 class="display-4 fw-bold">@Model.LowFundingCount</h2>
                    <p class="card-text opacity-75">Initiatives with zero recorded contributions.</p>
                </div>
            </div>
        </div>
    </div>

    @* Quick Management Links *@
    <div class="row justify-content-center mt-5">
        <div class="col-md-10">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-center">Quick Management Links</h5>
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="ManageInitiatives" class="btn btn-primary btn-lg px-5 shadow-sm">
                            <i class="bi bi-kanban"></i> Manage Initiatives
                        </a>
                        <a asp-action="Reports" class="btn btn-success btn-lg px-5 shadow-sm">
                            <i class="bi bi-graph-up-arrow"></i> Impact Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>